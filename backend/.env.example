# GoalVision AI — backend environment
# Copy to .env and fill in to enable AI providers.
# Provider priority is determined by the router at runtime:
#   GPT OSS 120B (NVIDIA NIM) → Gemini Pro → Gemini Flash → Nemotron → MiniMax → Mock

PORT=4000
CORS_ORIGIN=http://localhost:5173

# ── GPT OSS 120B (via NVIDIA NIM) ────────────────────────────────────────────
# Uses OpenAI-compatible endpoint at https://integrate.api.nvidia.com/v1
# Highest priority when set.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=openai/gpt-oss-120b

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Enables both Gemini 2.5 Pro (for tactical analysis) and Gemini 2.5 Flash (for chat).
GEMINI_API_KEY=
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

# ── NVIDIA Nemotron Ultra ─────────────────────────────────────────────────────
NVIDIA_API_KEY=
NEMOTRON_MODEL=nvidia/nemotron-ultra

# ── MiniMax M3 ────────────────────────────────────────────────────────────────
# Falls back to NVIDIA_API_KEY if MINIMAX_MODEL is set but MINIMAX_API_KEY is not.
MINIMAX_MODEL=minimax-m3

# ── Default provider override ─────────────────────────────────────────────────
# Not yet implemented — reserved for future use.
# DEFAULT_PROVIDER=gpt-oss
