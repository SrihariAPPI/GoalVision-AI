# GoalVision AI — backend environment
# Copy to .env and fill in to enable IBM Granite. Leave blank to use the built-in MockProvider.

PORT=4000
CORS_ORIGIN=http://localhost:5173

# IBM watsonx.ai (Granite) — optional. If any are missing, the API auto-falls back to MockProvider.
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct
